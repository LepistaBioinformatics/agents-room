{
  "name": "agent-room-ui",
  "version": "0.2.0",
  "description": "Visual canvas for Claude Code agent teams",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "cross-env NO_SANDBOX=1 electron-vite dev",
    "build": "electron-vite build && electron-builder",
    "build:unpack": "electron-vite build && electron-builder --dir",
    "build:win": "electron-vite build && electron-builder --win",
    "build:linux": "electron-vite build && electron-builder --linux",
    "build:all": "electron-vite build && electron-builder --win --linux",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "release:patch": "npm version patch -m 'chore: release v%s' && git push --follow-tags",
    "release:minor": "npm version minor -m 'chore: release v%s' && git push --follow-tags",
    "release:major": "npm version major -m 'chore: release v%s' && git push --follow-tags"
  },
  "keywords": [
    "electron",
    "claude-code",
    "agents"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "yarn@1.22.22",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@google/genai": "^1.48.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "gray-matter": "^4.0.3",
    "i18next": "^26.0.3",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.2",
    "react-markdown": "^9.0.1",
    "react-zoom-pan-pinch": "^3.7.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^2.0.0",
    "@electron-toolkit/eslint-config-ts": "^2.0.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.11"
  }
}
